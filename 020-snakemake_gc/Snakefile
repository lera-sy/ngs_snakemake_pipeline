
rule all:
    input:
        "030.output/output.tsv"

# Calculates GC% for one fasta file, writes a single number to a .gc file
rule calc_gc:
    input:
        "{sample}.fa"
    output:
        "030.output/{sample}.gc"
    run:
        with open(input[0]) as f:
            seq = "".join(line.strip() for line in f if not line.startswith(">"))
        gc = (seq.upper().count('G') + seq.upper().count('C')) / len(seq) * 100
        import os; os.makedirs("030.output", exist_ok=True)
        with open(output[0], 'w') as out:
            out.write(f"{gc:.2f}\n")

# Combines the two .gc files
rule create_tsv:
    input:
        expand("030.output/{sample}.gc", sample=["test1", "test2"])
    output:
        "030.output/output.tsv"
    run:
        with open(output[0], 'w') as tsv:
            for gc_file in input:
                sample = gc_file.replace("030.output/", "").replace(".gc", "")
                with open(gc_file) as f:
                    perc = f.read().strip()
                tsv.write(f"{sample}\t{perc}\n")
